#!/bin/bash
"""
HexStrike Pulse — single entry point for Claude Desktop
=======================================================
Usage:
  ./hexstrike-pulse           Start MCP stdio server (Claude Desktop)
  ./hexstrike-pulse --debug   Start with debug logging
  ./hexstrike-pulse --help    Show help

What this does:
  1. Auto-activates the hexstrike virtual environment
  2. Clears stale lock file (/tmp/hexstrike_mcp.lock) if older than 30s
  3. Runs hexstrike_mcp.py in MCP stdio mode (the ONLY mode Claude Desktop supports)

Claude Desktop config:
  {
    "mcpServers": {
      "hexstrike-pulse": {
        "command": "/full/path/to/hexstrike-pulse",
        "args": ["--debug"]
      }
    }
  }
"""

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR" || exit 1

# Auto-activate venv
if [ -f hexstrike-env/bin/activate ]; then
    # shellcheck disable=SC1091
    source hexstrike-env/bin/activate
fi

# Clean stale lock file (>30s old = stale)
LOCK_FILE="/tmp/hexstrike_mcp.lock"
if [ -f "$LOCK_FILE" ]; then
    if [ "$(($(date +%s) - $(stat -c %Y "$LOCK_FILE" 2>/dev/null || echo 0)))" -gt 30 ]; then
        rm -f "$LOCK_FILE" 2>/dev/null
    fi
fi

exec python3 hexstrike_mcp.py "$@"
