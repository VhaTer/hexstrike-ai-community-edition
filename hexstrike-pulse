#!/bin/bash
# =============================================================================
# HexStrike Pulse — unified MCP server launcher
#
# USAGE:
#
#   ./hexstrike-pulse                Start HTTP server in background
#   ./hexstrike-pulse --foreground   Start in foreground (logs visible)
#   ./hexstrike-pulse --bridge       Stdio→HTTP bridge (for Claude Desktop)
#   ./hexstrike-pulse stop           Stop the background server
#   ./hexstrike-pulse status         Check if server is running
#   ./hexstrike-pulse --debug        Start with debug logging
#
# WORKFLOW (recommended):
#
#   Terminal 1: ./hexstrike-pulse              # start HTTP server (once)
#   Claude Desktop: connects via --bridge mode  # instant, no import cost
#   Opencode/Continue: http://localhost:8888/mcp # remote URL
#
# CLAUDE DESKTOP CONFIG:
#
#   { "mcpServers": {
#     "hexstrike-pulse": {
#       "command": "wsl.exe",
#       "args": ["-d", "kali-linux", "/abs/path/hexstrike-pulse", "--bridge"]
#     }
#   }}
#
#   Replace: kali-linux → your distro, /abs/path → pwd output.
#
# OPENCODE CONFIG:
#
#   { "mcp": { "hexstrike-pulse": { "type": "remote", "url": "http://localhost:8888/mcp" } } }
#
# All clients share the same HTTP server — no lock conflicts, instant startup.
# =============================================================================

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PIDFILE="/tmp/hexstrike-pulse.pid"
PORT=8888
HOST="0.0.0.0"

# ── helpers ──────────────────────────────────────────────────────────────────

_wsl_detect() {
    case "$(uname -r)" in
        *[Mm]icrosoft*) return 0 ;;
        *[Ww]sl*)      return 0 ;;
        *)             return 1 ;;
    esac
}

_wsl_ip() {
    hostname -I 2>/dev/null | awk '{print $1}'
}

_pid_alive() {
    [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null
}

_port_listening() {
    ss -tlnp 2>/dev/null | grep -q ":$PORT "
}

_print_connection_info() {
    local ip
    echo ""
    echo "  ⚡ HexStrike Pulse — http://localhost:${PORT}/mcp"
    echo ""
    echo "  ── Clients ──"
    echo "  Claude Desktop → http://localhost:${PORT}/mcp"
    echo "  Opencode       → type: remote, url: http://localhost:${PORT}/mcp"
    if _wsl_detect; then
        ip="$(_wsl_ip)"
        if [ -n "$ip" ]; then
            echo ""
            echo "  ── WSL ──"
            echo "  http://${ip}:${PORT}/mcp  (if localhost fails)"
        fi
    fi
    echo ""
    echo "  ── Commands ──"
    echo "  ./hexstrike-pulse stop       Stop server"
    echo "  ./hexstrike-pulse status     Check status"
    echo "  ./hexstrike-pulse --foreground  Foreground with logs"
    echo "  ./hexstrike-pulse --debug    Debug logging"
    echo ""
}

_ensure_venv() {
    if [ -f "$SCRIPT_DIR/hexstrike-env/bin/activate" ]; then
        # shellcheck disable=SC1091
        source "$SCRIPT_DIR/hexstrike-env/bin/activate"
    fi
}

# ── commands ─────────────────────────────────────────────────────────────────

cmd_stop() {
    if [ -f "$PIDFILE" ]; then
        local pid
        pid=$(cat "$PIDFILE" 2>/dev/null)
        if kill "$pid" 2>/dev/null; then
            echo "✅ Pulse server (PID $pid) stopped."
        else
            echo "⚠️  No process found for PID $pid — removing stale PID file."
        fi
        rm -f "$PIDFILE"
    else
        echo "ℹ️  No PID file — server not running (or crashed)."
        if _port_listening; then
            echo "   Port $PORT is still in use. Kill manually: fuser -k $PORT/tcp"
        fi
    fi
    rm -f /tmp/hexstrike_mcp.lock
}

cmd_status() {
    if _pid_alive; then
        local pid
        pid=$(cat "$PIDFILE")
        echo "✅ Pulse server running (PID $pid, port $PORT)"
        _print_connection_info
        return 0
    fi
    if _port_listening; then
        echo "⚠️  Port $PORT is in use but no PID file — stale server from another session?"
        echo "   Run './hexstrike-pulse stop' to clean up."
    else
        echo "❌ Pulse server not running."
    fi
    return 1
}

cmd_help() {
    echo "HexStrike Pulse — unified MCP server launcher"
    echo ""
    echo "Usage:"
    echo "  ./hexstrike-pulse              Start HTTP server (background)"
    echo "  ./hexstrike-pulse --foreground  Foreground with logs"
    echo "  ./hexstrike-pulse --bridge      Stdio→HTTP bridge (Claude Desktop)"
    echo "  ./hexstrike-pulse --debug       Debug logging"
    echo "  ./hexstrike-pulse stop          Stop server"
    echo "  ./hexstrike-pulse status        Check status"
    echo "  ./hexstrike-pulse -h,--help     This help"
}

cmd_stdio() {
    cd "$SCRIPT_DIR" || exit 1
    _ensure_venv
    exec python3 -u hexstrike_mcp.py "$@"
}

cmd_bridge() {
    # stdio→HTTP bridge — requires HTTP server to be running
    cd "$SCRIPT_DIR" || exit 1
    _ensure_venv
    exec python3 -u pulse-bridge.py "$@"
}

cmd_foreground() {
    cd "$SCRIPT_DIR" || exit 1
    _ensure_venv
    echo "🔵 Pulse HTTP server — foreground (Ctrl+C to stop)"
    echo ""
    exec python3 hexstrike_mcp.py --transport http --host "$HOST" --port "$PORT" "$@"
}

cmd_background() {
    cd "$SCRIPT_DIR" || exit 1
    _ensure_venv

    # Build args: always add HTTP transport unless user overrides
    local args="--transport http --host $HOST --port $PORT $*"

    nohup python3 hexstrike_mcp.py $args >> hexstrike.log 2>&1 &
    local pid=$!
    echo "$pid" > "$PIDFILE"

    # Wait for port to be ready (up to 8 seconds)
    local waited=0
    while [ $waited -lt 8 ]; do
        if _port_listening; then
            _print_connection_info
            echo "  PID $pid — tail -f hexstrike.log"
            echo ""
            exit 0
        fi
        sleep 1
        waited=$((waited + 1))
    done

    echo "⚠️  Server started but port $PORT not yet listening:"
    echo "   tail -20 hexstrike.log"
    exit 1
}

# ── dispatch ─────────────────────────────────────────────────────────────────

cd "$SCRIPT_DIR" || exit 1

case "${1:-}" in
    stop)       shift; cmd_stop "$@" ;;
    status)     shift; cmd_status "$@" ;;
    --stdio)    shift; cmd_stdio "$@" ;;
    --bridge)   shift; cmd_bridge "$@" ;;
    --foreground|-f) shift; cmd_foreground "$@" ;;
    --help|-h)      shift; cmd_help "$@" ;;
    *)
        if [ -f "$PIDFILE" ] && _port_listening; then
            cmd_status
            exit 0
        fi
        cmd_background "$@"
        ;;
esac
